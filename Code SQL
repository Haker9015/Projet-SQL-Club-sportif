-- On recrée la base toute neuve
CREATE DATABASE GestionClubSportif;
GO

USE GestionClubSportif;
GO


-- Création des tables indépendantes
CREATE TABLE SPORT (
    IdSport INT PRIMARY KEY IDENTITY(1,1),
    NomSport VARCHAR(50) NOT NULL -- Ex: Football, Basketball
);

CREATE TABLE ENTRAINEUR (
    IdEntraineur INT PRIMARY KEY IDENTITY(1,1),
    Nom VARCHAR(50) NOT NULL,
    Prenom VARCHAR(50) NOT NULL,
    Diplome VARCHAR(100) --
);

CREATE TABLE STADE (
    IdStade INT PRIMARY KEY IDENTITY(1,1),
    NomStade VARCHAR(100) NOT NULL,
    Ville VARCHAR(50),
    TypeSurface VARCHAR(50) --
);

CREATE TABLE COMPETITION (
    IdCompetition INT PRIMARY KEY IDENTITY(1,1),
    NomCompete VARCHAR(100) NOT NULL, -- Ex: Championnat District
    Saison VARCHAR(20) NOT NULL -- Ex: 2025-2026
);

-- Création des tables avec dépendances
CREATE TABLE EQUIPE (
    IdEquipe INT PRIMARY KEY IDENTITY(1,1),
    NomEquipe VARCHAR(100) NOT NULL,
    Categorie VARCHAR(50), -- Ex: Senior, U18
    IdSport INT NOT NULL,
    IdEntraineur INT,
    CONSTRAINT FK_Equipe_Sport FOREIGN KEY (IdSport) REFERENCES SPORT(IdSport),
    CONSTRAINT FK_Equipe_Entraineur FOREIGN KEY (IdEntraineur) REFERENCES ENTRAINEUR(IdEntraineur)
);

CREATE TABLE JOUEUR (
    IdJoueur INT PRIMARY KEY IDENTITY(1,1),
    Nom VARCHAR(50) NOT NULL,
    Prenom VARCHAR(50) NOT NULL,
    DateNaissance DATE,
    Adresse VARCHAR(255),
    IdEquipe INT, --
    CONSTRAINT FK_Joueur_Equipe FOREIGN KEY (IdEquipe) REFERENCES EQUIPE(IdEquipe)
);

CREATE TABLE LICENCE (
    NumLicence VARCHAR(20) PRIMARY KEY, -- Identifiant unique de licence
    DateEmission DATE NOT NULL,
    Prix DECIMAL(10,2),
    StatutPaiement VARCHAR(20) DEFAULT 'A jour',
    IdJoueur INT NOT NULL,
    CONSTRAINT FK_Licence_Joueur FOREIGN KEY (IdJoueur) REFERENCES JOUEUR(IdJoueur)
);

-- Gestion des Matchs et des contraintes métier
CREATE TABLE MATCH (
    IdMatch INT PRIMARY KEY IDENTITY(1,1),
    DateMatch DATE NOT NULL,
    HeureMatch TIME NOT NULL,
    IdStade INT NOT NULL,
    IdCompetition INT NOT NULL,
    IdEquipeDom INT NOT NULL,
    IdEquipeExt INT NOT NULL,
    
    -- Contrainte : Une équipe ne peut pas jouer contre elle-même
    CONSTRAINT CHK_Equipes_Differentes CHECK (IdEquipeDom <> IdEquipeExt),
    
    CONSTRAINT FK_Match_Stade FOREIGN KEY (IdStade) REFERENCES STADE(IdStade),
    CONSTRAINT FK_Match_Compete FOREIGN KEY (IdCompetition) REFERENCES COMPETITION(IdCompetition),
    CONSTRAINT FK_Match_Dom FOREIGN KEY (IdEquipeDom) REFERENCES EQUIPE(IdEquipe),
    CONSTRAINT FK_Match_Ext FOREIGN KEY (IdEquipeExt) REFERENCES EQUIPE(IdEquipe)
);

-- Application de la contrainte métier : "Une équipe ne peut jouer qu'un match programmé"
-- Note : On utilise des index uniques pour empêcher qu'une équipe (dom ou ext) soit prise sur le même créneau.
CREATE UNIQUE INDEX UNQ_EquipeDom_Planning ON MATCH (IdEquipeDom, DateMatch, HeureMatch);
CREATE UNIQUE INDEX UNQ_EquipeExt_Planning ON MATCH (IdEquipeExt, DateMatch, HeureMatch);

-- Gestion des Scores (Entité principale distincte)
CREATE TABLE SCORE (
    IdScore INT PRIMARY KEY IDENTITY(1,1),
    PointsDomicile INT DEFAULT 0,
    PointsExterieur INT DEFAULT 0,
    IdMatch INT UNIQUE NOT NULL, --
    CONSTRAINT FK_Score_Match FOREIGN KEY (IdMatch) REFERENCES MATCH(IdMatch)
);


