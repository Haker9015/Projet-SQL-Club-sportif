-- Pratique de quelques requêtes pour répondre aux besoins de gestion du club:

-- Exemple de Planning des Rencontres

SELECT 
    M.DateMatch, 
    M.HeureMatch, 
    E1.NomEquipe AS Domicile, 
    E2.NomEquipe AS Exterieur, 
    S.NomStade
FROM MATCH M
JOIN EQUIPE E1 ON M.IdEquipeDom = E1.IdEquipe
JOIN EQUIPE E2 ON M.IdEquipeExt = E2.IdEquipe
JOIN STADE S ON M.IdStade = S.IdStade;

-- Statistiques des Joueurs et Licences
SELECT 
    J.Nom, 
    J.Prenom, 
    E.NomEquipe, 
    L.NumLicence, 
    L.StatutPaiement
FROM JOUEUR J
JOIN EQUIPE E ON J.IdEquipe = E.IdEquipe
LEFT JOIN LICENCE L ON J.IdJoueur = L.IdJoueur;

-- Le Classement (Résultats des Matchs)

SELECT 
    M.DateMatch,
    E1.NomEquipe AS Equipe_Dom,
    S.PointsDomicile,
    S.PointsExterieur,
    E2.NomEquipe AS Equipe_Ext
FROM SCORE S
JOIN MATCH M ON S.IdMatch = M.IdMatch
JOIN EQUIPE E1 ON M.IdEquipeDom = E1.IdEquipe
JOIN EQUIPE E2 ON M.IdEquipeExt = E2.IdEquipe;
